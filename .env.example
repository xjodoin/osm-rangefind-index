# rclone destination for the published index: <remote>:<bucket>[/prefix]
# Configure the remote once with: rclone config  (type: s3, provider: Cloudflare)
# or purely via environment as below.
R2_REMOTE=r2:osm-index

# Optional pure-env rclone remote named "r2" (no rclone.conf needed):
#RCLONE_CONFIG_R2_TYPE=s3
#RCLONE_CONFIG_R2_PROVIDER=Cloudflare
#RCLONE_CONFIG_R2_ACCESS_KEY_ID=...
#RCLONE_CONFIG_R2_SECRET_ACCESS_KEY=...
#RCLONE_CONFIG_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
