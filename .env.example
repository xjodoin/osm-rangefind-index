# Direct Cloudflare R2/S3 configuration (no rclone dependency).
R2_BUCKET=osm-index
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
# Optional key prefix within the bucket.
#R2_PREFIX=

# One shared request pool batches object operations across every active shard
# upload. Two shard lanes overlap R2 latency while the next shard builds; the
# pending depth bounds local artifacts awaiting upload/cleanup.
R2_REQUEST_CONCURRENCY=16
R2_UPLOAD_ATTEMPTS=6
R2_UPLOAD_LANES=2
R2_UPLOAD_QUEUE_DEPTH=4

# The final cross-shard suggest_prefix routing merge runs in an isolated child
# process so the long-lived orchestrator stays small. The production host has
# enough RAM for a larger heap during this one bounded operation.
TEXT_ROUTING_HEAP_MB=12288
# The root merge groups sorted autocomplete keys by this physical prefix
# depth. Ten means "s|" plus eight normalized characters, keeping common
# planet-scale prefixes bounded without changing query behavior.
SUGGEST_ROUTING_BASE_SHARD_DEPTH=10
SUGGEST_ROUTING_MAX_SHARD_DEPTH=14
SUGGEST_ROUTING_HEAP_MB=8192

# Corpus diffs use an id/hash map proportional to the region size. Isolating
# it lets the host use available RAM for large regions and reclaim it fully
# before the next shard.
CORPUS_DIFF_HEAP_MB=16384
